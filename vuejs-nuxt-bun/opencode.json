{
	"$schema": "https://opencode.ai/config.json",
	"lsp": {
		"vue-typescript": {
			"command": ["bunx", "--yes", "typescript-language-server", "--stdio"],
			"extensions": [".vue", ".ts", ".tsx", ".mts", ".cts", ".js", ".jsx", ".mjs", ".cjs"],
			"initialization": {
				"plugins": [
					{
						"name": "@vue/typescript-plugin",
						"location": "@vue/typescript-plugin",
						"languages": ["vue"]
					}
				]
			}
		}
	}
}
